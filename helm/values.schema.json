{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of web application replicas."
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "description": "Overrides the image tag. Defaults to Chart appVersion when empty."
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["IfNotPresent", "Always", "Never"]
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "nodePort": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 65535,
          "description": "NodePort value. Only used when service.type is NodePort. Null for auto-assignment."
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bindAddress": {
          "type": "string",
          "description": "Address for the web server to listen on, e.g. :8080.",
          "pattern": "^(.*)?:[0-9]+$"
        },
        "uploadServiceURL": {
          "type": "string",
          "description": "Base URL of the upload service. Defaults to the internal service URL when empty."
        },
        "cookieSecure": {
          "type": "string",
          "enum": ["true", "false"],
          "description": "Set to false only when running without TLS (e.g. local development)."
        },
        "allowPrivateUploads": {
          "type": "string",
          "enum": ["true", "false"],
          "description": "When false, the private upload option is hidden from the upload form."
        },
        "allowSingleUseLinks": {
          "type": "string",
          "enum": ["true", "false"],
          "description": "When false, the single-use link option is hidden from the upload form."
        },
        "replicatedSDKURL": {
          "type": "string",
          "description": "Base URL of the Replicated SDK service. Defaults to http://replicated:3000 when empty."
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uploadAdminToken": {
          "type": "string",
          "description": "Preset admin token for the upload service."
        },
        "adminPassword": {
          "type": "string",
          "description": "Preset password for the web UI admin user. Randomly generated on first start when empty."
        },
        "databaseURL": {
          "type": "string",
          "description": "PostgreSQL connection URL (e.g. postgres://user:pass@host:5432/db). Required when postgres.internal is false."
        }
      }
    },
    "postgres": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "internal": {
          "type": "boolean",
          "default": true,
          "description": "When true, deploys a CloudNativePG cluster. When false, an external PostgreSQL URL must be provided via secrets.databaseURL."
        },
        "instances": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of CloudNativePG cluster instances."
        },
        "database": {
          "type": "string",
          "minLength": 1
        },
        "user": {
          "type": "string",
          "minLength": 1
        },
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["size"],
          "properties": {
            "size": {
              "$ref": "#/$defs/k8sQuantity"
            },
            "storageClass": {
              "type": "string"
            }
          }
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "tag"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "upload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "internal": {
          "type": "boolean",
          "description": "Deploy the bundled upload service. Set to false to use an external upload service; config.uploadServiceURL must be provided."
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "tag"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["IfNotPresent", "Always", "Never"]
            }
          }
        },
        "ttl": {
          "type": "string",
          "pattern": "^([0-9]+(ns|us|µs|ms|s|m|h))+$|^$",
          "description": "File retention duration (e.g. 24h, 7d). Empty falls back to the upload service default (24h)."
        },
        "maxUploadBytes": {
          "type": ["string", "integer"],
          "pattern": "^[0-9]*$",
          "description": "Maximum upload size in bytes. Empty falls back to the upload service default (2 GiB)."
        },
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["size"],
          "properties": {
            "size": {
              "$ref": "#/$defs/k8sQuantity"
            },
            "storageClass": {
              "type": "string"
            }
          }
        },
        "resources": {
          "$ref": "#/$defs/resourceRequirements"
        }
      }
    },
    "resources": {
      "$ref": "#/$defs/resourceRequirements"
    },
    "livenessProbe": {
      "$ref": "#/$defs/httpProbe"
    },
    "readinessProbe": {
      "$ref": "#/$defs/httpProbe"
    },
    "gateway": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string",
          "description": "Hostname the application is served on."
        },
        "tls": {
          "type": "boolean",
          "description": "Enable TLS via the Traefik letsencrypt cert resolver."
        }
      }
    },
    "global": {
      "type": "object",
      "description": "Global values injected by Replicated at install time (e.g. global.replicated)."
    },
    "replicated": {
      "type": "object",
      "description": "Values passed through to the Replicated SDK subchart."
    }
  },
  "if": {
    "properties": {
      "postgres": {
        "properties": {
          "internal": { "const": false }
        },
        "required": ["internal"]
      }
    }
  },
  "then": {
    "properties": {
      "secrets": {
        "required": ["databaseURL"],
        "properties": {
          "databaseURL": {
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "k8sQuantity": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)?(Ki|Mi|Gi|Ti|Pi|Ei|k|M|G|T|P|E|m)?$",
      "description": "A Kubernetes resource quantity, e.g. 5Gi, 512Mi, 100m."
    },
    "resourceRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "$ref": "#/$defs/k8sQuantity" },
            "memory": { "$ref": "#/$defs/k8sQuantity" }
          }
        },
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": { "$ref": "#/$defs/k8sQuantity" },
            "memory": { "$ref": "#/$defs/k8sQuantity" }
          }
        }
      }
    },
    "httpProbe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "httpGet": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "port"],
          "properties": {
            "path": { "type": "string" },
            "port": { "type": ["string", "integer"] }
          }
        },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 },
        "successThreshold": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
